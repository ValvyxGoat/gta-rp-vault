# Copiez ce fichier en .env.local et remplissez les valeurs

# Supabase - Récupérez ces valeurs sur https://app.supabase.com
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Mot de passe global du site (haché en SHA-256 pour plus de sécurité)
# Pour générer le hash de votre mot de passe, utilisez: https://emn178.github.io/online-tools/sha256.html
# Exemple: "monmotdepasse" → hash SHA-256
VITE_APP_PASSWORD_HASH=votre_hash_sha256_ici
